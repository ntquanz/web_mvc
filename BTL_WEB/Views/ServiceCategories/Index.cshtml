@model IEnumerable<BTL_WEB.Models.ServiceCategory>

@{
    ViewData["Title"] = "Service Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Service Categories</h1>
    <a asp-action="Create" class="btn btn-primary">Create Category</a>
</div>

<table class="table table-bordered">
    <thead><tr><th>Name</th><th>Description</th><th>Services</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CategoryName</td>
            <td>@item.Description</td>
            <td>@item.Services.Count</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
