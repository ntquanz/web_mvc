@model BTL_WEB.Models.Appointment
@{
    ViewData["Title"] = "Appointment Details";
    var totalAmount = (decimal)(ViewBag.TotalAmount ?? 0m);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Appointment #@Model.AppointmentId</h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a asp-action="EditStatus" asp-route-id="@Model.AppointmentId" class="btn btn-primary">Edit Status</a>
        }
        @if ((User.IsInRole("Admin") || User.IsInRole("Staff")) && Model.Status == "Completed")
        {
            <a asp-controller="Payments" asp-action="Create" asp-route-appointmentId="@Model.AppointmentId" class="btn btn-success">Create Payment</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-6">
        <div class="card"><div class="card-body">
            <p><strong>User:</strong> @Model.User.FullName</p>
            <p><strong>Pet:</strong> @Model.Pet.Name</p>
            <p><strong>Branch:</strong> @Model.Branch.BranchName</p>
            <p><strong>Date:</strong> @Model.AppointmentDateTime.ToString("g")</p>
            <p><strong>Status:</strong> <span id="appointment-status-text">@Model.Status</span></p>
            <p><strong>Notes:</strong> @Model.Notes</p>
            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
            {
                <div id="appointment-status-message"></div>
                <form asp-action="EditStatus" method="post" id="appointment-status-form" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AppointmentId" value="@Model.AppointmentId" />
                    <div class="input-group">
                        <select name="Status" class="form-select">
                            @foreach (var status in new[] { "Pending", "Confirmed", "Completed", "Cancelled" })
                            {
                                if (Model.Status == status)
                                {
                                    <option value="@status" selected>@status</option>
                                }
                                else
                                {
                                    <option value="@status">@status</option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn btn-outline-primary">Update Status</button>
                    </div>
                </form>
            }
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="card"><div class="card-body">
            <h2 class="h5">Services</h2>
            <table class="table table-sm">
                <thead><tr><th>Service</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
                <tbody>
                @foreach (var item in Model.AppointmentServices)
                {
                    <tr>
                        <td>@item.Service.ServiceName</td>
                        <td>@item.UnitPrice.ToString("N0")</td>
                        <td>@item.Quantity</td>
                        <td>@((item.UnitPrice * item.Quantity).ToString("N0"))</td>
                    </tr>
                }
                </tbody>
                <tfoot><tr><th colspan="3">Total</th><th>@totalAmount.ToString("N0")</th></tr></tfoot>
            </table>
        </div></div>
    </div>
    <div class="col-12">
        <div class="card"><div class="card-body">
            <h2 class="h5">Payments</h2>
            <table class="table table-sm">
                <thead><tr><th>Date</th><th>Method</th><th>Status</th><th>Amount</th></tr></thead>
                <tbody>
                @foreach (var item in Model.Payments.OrderByDescending(x => x.PaymentDate))
                {
                    <tr>
                        <td>@item.PaymentDate.ToString("g")</td>
                        <td>@item.PaymentMethod</td>
                        <td>@item.PaymentStatus</td>
                        <td>@item.Amount.ToString("N0")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div></div>
    </div>
</div>
@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('appointment-status-form');
            if (!form) return;

            const messageBox = document.getElementById('appointment-status-message');
            const statusText = document.getElementById('appointment-status-text');

            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new FormData(form)
                });

                const payload = await response.json().catch(() => null);
                if (!response.ok || !payload?.success) {
                    messageBox.innerHTML = `<div class="alert alert-danger mt-2">${payload?.message ?? 'Cap nhat that bai.'}</div>`;
                    return;
                }

                statusText.textContent = payload.status;
                messageBox.innerHTML = `<div class="alert alert-success mt-2">${payload.message}</div>`;
            });
        })();
    </script>
}
