@model IEnumerable<BTL_WEB.Models.Payment>
@{
    ViewData["Title"] = "Payments";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Payments</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <a asp-action="Create" class="btn btn-primary">Create Payment</a>
    }
</div>
<table class="table table-bordered">
    <thead><tr><th>Date</th><th>Reference</th><th>Method</th><th>Status</th><th>Amount</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.PaymentDate.ToString("g")</td>
            <td>@(item.AppointmentId.HasValue ? $"Appointment #{item.AppointmentId}" : $"Contract #{item.ContractId}")</td>
            <td>@item.PaymentMethod</td>
            <td>@item.PaymentStatus</td>
            <td>@item.Amount.ToString("N0")</td>
            <td><a asp-action="Details" asp-route-id="@item.PaymentId" class="btn btn-sm btn-outline-info">Details</a></td>
        </tr>
    }
    </tbody>
</table>
