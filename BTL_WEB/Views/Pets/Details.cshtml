@model BTL_WEB.Models.Pet
@{
    ViewData["Title"] = "Pet Details";
    var uploadModel = ViewBag.UploadModel as BTL_WEB.ViewModels.Pets.UploadPetImageViewModel;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.Name</h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a asp-action="Edit" asp-route-id="@Model.PetId" class="btn btn-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <p><strong>Species:</strong> @Model.Species</p>
                <p><strong>Branch:</strong> @Model.Branch.BranchName</p>
                <p><strong>Owner:</strong> @(Model.Owner?.FullName ?? "-")</p>
                <p><strong>Adoption status:</strong> @Model.AdoptionStatus</p>
                <p><strong>Health status:</strong> @Model.HealthStatus</p>
                <p><strong>Description:</strong> @Model.Description</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Images</h2>
                <div class="row g-2">
                    @foreach (var image in Model.PetImages)
                    {
                        <div class="col-md-6">
                            <img src="@image.ImageUrl" alt="@Model.Name" class="img-fluid rounded border" />
                        </div>
                    }
                </div>
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                    <div id="pet-upload-message"></div>
                    <form asp-action="UploadImages" method="post" enctype="multipart/form-data" class="mt-3" id="pet-upload-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PetId" value="@uploadModel?.PetId" />
                        <input type="file" name="ImageFiles" class="form-control" multiple accept=".jpg,.jpeg,.png" />
                        <button type="submit" class="btn btn-outline-primary mt-2">Upload</button>
                    </form>
                }
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Medical Records</h2>
                <table class="table table-sm">
                    <thead><tr><th>Date</th><th>Diagnosis</th><th>Treatment</th><th>Staff</th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.MedicalRecords.OrderByDescending(x => x.VisitDate))
                    {
                        <tr>
                            <td>@item.VisitDate.ToString("g")</td>
                            <td>@item.Diagnosis</td>
                            <td>@item.Treatment</td>
                            <td>@item.Staff.User.FullName</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Vaccinations</h2>
                <table class="table table-sm">
                    <thead><tr><th>Vaccine</th><th>Date</th><th>Next due</th><th>Staff</th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Vaccinations.OrderByDescending(x => x.VaccinationDate))
                    {
                        <tr>
                            <td>@item.VaccineName</td>
                            <td>@item.VaccinationDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.NextDueDate?.ToString("yyyy-MM-dd")</td>
                            <td>@item.Staff.User.FullName</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Appointments</h2>
                <table class="table table-sm">
                    <thead><tr><th>Date</th><th>Status</th><th>Services</th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Appointments.OrderByDescending(x => x.AppointmentDateTime))
                    {
                        <tr>
                            <td>@item.AppointmentDateTime.ToString("g")</td>
                            <td>@item.Status</td>
                            <td>@string.Join(", ", item.AppointmentServices.Select(x => x.Service.ServiceName))</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('pet-upload-form');
            if (!form) return;

            const messageBox = document.getElementById('pet-upload-message');
            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new FormData(form)
                });

                const payload = await response.json().catch(() => null);
                if (!response.ok || !payload?.success) {
                    messageBox.innerHTML = `<div class="alert alert-danger mt-2">${payload?.message ?? 'Upload anh that bai.'}</div>`;
                    return;
                }

                messageBox.innerHTML = `<div class="alert alert-success mt-2">${payload.message}</div>`;
                window.location.reload();
            });
        })();
    </script>
}
