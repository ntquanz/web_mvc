@model BTL_WEB.ViewModels.Pets.PetFormViewModel

<form asp-action="@(Model.PetId.HasValue ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
    @if (Model.PetId.HasValue)
    {
        <input asp-for="PetId" type="hidden" />
    }

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Species" class="form-label"></label>
            <input asp-for="Species" class="form-control" />
            <span asp-validation-for="Species" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Breed" class="form-label"></label>
            <input asp-for="Breed" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Gender" class="form-label"></label>
            <input asp-for="Gender" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="DateOfBirth" class="form-label"></label>
            <input asp-for="DateOfBirth" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Weight" class="form-label"></label>
            <input asp-for="Weight" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="HealthStatus" class="form-label"></label>
            <input asp-for="HealthStatus" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="VaccinationStatus" class="form-label"></label>
            <input asp-for="VaccinationStatus" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="AdoptionStatus" class="form-label"></label>
            <select asp-for="AdoptionStatus" class="form-select">
                <option value="Available">Available</option>
                <option value="Pending">Pending</option>
                <option value="Adopted">Adopted</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="BranchId" class="form-label">Branch</label>
            <select asp-for="BranchId" class="form-select" asp-items="Model.BranchOptions"></select>
            <span asp-validation-for="BranchId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="OwnerId" class="form-label">Owner</label>
            <select asp-for="OwnerId" class="form-select" asp-items="Model.OwnerOptions"></select>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
            <label asp-for="ImageFiles" class="form-label">Pet images</label>
            <input asp-for="ImageFiles" type="file" class="form-control" multiple accept=".jpg,.jpeg,.png" />
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>
