@model BTL_WEB.Models.ViewModels.AdoptionsPageViewModel

@{
    Layout = "_Layout";
    var isStaffOrAdmin = ViewBag.IsStaffOrAdmin as bool? == true;
    ViewData["Title"] = isStaffOrAdmin ? "Quản lý nhận nuôi" : "Nhận nuôi của tôi";

    string ResolveImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return Url.Content("~/LayoutPetcare/images/gallery-1.jpg");
        }

        imageUrl = imageUrl.Replace("\\", "/");
        if (Uri.IsWellFormedUriString(imageUrl, UriKind.Absolute))
        {
            return imageUrl;
        }

        return imageUrl.StartsWith("/") ? Url.Content($"~{imageUrl}") : Url.Content($"~/{imageUrl}");
    }
}

<section class="ftco-section bg-light">
    <div class="container">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (!isStaffOrAdmin)
        {
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="card p-3">
                        <h5 class="mb-3">Danh sách thú cưng có thể nhận nuôi</h5>
                        <div class="row">
                            @if (Model.AvailablePets.Count == 0)
                            {
                                <div class="col-12">
                                    <div class="alert alert-light border text-center text-muted mb-0">Hiện chưa có thú cưng ở trạng thái Có sẵn.</div>
                                </div>
                            }
                            else
                            {
                                @foreach (var pet in Model.AvailablePets)
                                {
                                    <div class="col-md-4 mb-3">
                                        <div class="card border-0 shadow-sm h-100">
                                            <img src="@ResolveImageUrl(pet.PrimaryImageUrl)"
                                                 alt="@pet.Name"
                                                 class="card-img-top"
                                                 style="height:220px;object-fit:cover;"
                                                 onerror="this.onerror=null;this.src='@Url.Content("~/LayoutPetcare/images/gallery-1.jpg")';" />
                                            <div class="card-body d-flex flex-column">
                                                <h5 class="mb-2">@pet.Name</h5>
                                                <p class="mb-1"><strong>Loài:</strong> @pet.Species</p>
                                                <p class="mb-1"><strong>Giống:</strong> @pet.Breed</p>
                                                <p class="mb-1"><strong>Giới tính:</strong> @pet.Gender</p>
                                                <p class="mb-1"><strong>Chi nhánh:</strong> @pet.BranchName</p>
                                                <p class="mb-3"><span class="badge @StatusDisplay.BadgeClass(pet.AdoptionStatus) px-2 py-1">@StatusDisplay.Label(pet.AdoptionStatus)</span></p>
                                                <button type="button" class="btn btn-primary mt-auto btn-open-adoption" data-pet-id="@pet.PetId" data-pet-name="@pet.Name">Gửi yêu cầu</button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!isStaffOrAdmin)
        {
            <div class="modal fade" id="adoptionRequestModal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Gửi yêu cầu nhận nuôi</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <form method="post" asp-action="CreateAdoptionRequest">
                            @Html.AntiForgeryToken()
                            <div class="modal-body">
                                <input type="hidden" id="requestPetId" name="petId" />
                                <p class="mb-2">Thú cưng: <strong id="requestPetName"></strong></p>
                                <label for="requestMessage">Lời nhắn</label>
                                <textarea class="form-control" id="requestMessage" name="message" rows="4" required placeholder="Nhập lý do / mong muốn khi nhận nuôi"></textarea>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-primary">Gửi yêu cầu</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <div class="row mb-4">
            <div class="col-md-12">
                <div class="p-4 rounded" style="background-image:url('@Url.Content("~/LayoutPetcare/images/bg_3.jpg")');background-size:cover;background-position:center;">
                    <div class="p-3" style="background:rgba(0,0,0,.45);border-radius:8px;">
                        <h3 class="text-white mb-1">@(isStaffOrAdmin ? "Module nhận nuôi" : "Thông tin nhận nuôi")</h3>
                        <p class="text-white mb-0">@(isStaffOrAdmin ? "Theo dõi yêu cầu nhận nuôi, hợp đồng và trạng thái thanh toán." : "Theo dõi yêu cầu, hợp đồng và thanh toán nhận nuôi của bạn.")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-12">
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-primary" href="#adoption-requests">Yêu cầu nhận nuôi</a>
                    <a class="btn btn-outline-primary" href="#adoption-contracts">Hợp đồng nhận nuôi</a>
                    <a class="btn btn-outline-primary" href="#adoption-payments">Thanh toán</a>
                </div>
            </div>
        </div>

        <div class="row justify-content-center mb-4">
            <div class="col-md-10 text-center heading-section ftco-animate">
                <h2>@(isStaffOrAdmin ? "Quản lý nhận nuôi" : "Nhận nuôi của tôi")</h2>
                <p>@(isStaffOrAdmin ? "Theo dõi dữ liệu nhận nuôi từ hệ thống." : "Xem trạng thái các yêu cầu nhận nuôi đã gửi bằng tài khoản của bạn.")</p>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card p-3">
                    <form method="get" class="row">
                        <div class="col-md-4 mb-2"><input class="form-control" disabled placeholder="Dữ liệu lấy từ database" /></div>
                        <div class="col-md-4 mb-2">
                            <select class="form-control" name="status">
                                <option>Tất cả yêu cầu</option>
                                <option value="Pending" selected="@(Model.Status == "Pending")">Đang chờ</option>
                                <option value="Approved" selected="@(Model.Status == "Approved")">Đã duyệt</option>
                                <option value="Rejected" selected="@(Model.Status == "Rejected")">Từ chối</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2"><button type="submit" class="btn btn-primary btn-block">Lọc yêu cầu</button></div>
                    </form>
                </div>
            </div>
        </div>

        <h4 class="mb-3" id="adoption-requests">Yêu cầu nhận nuôi</h4>
        <div class="table-responsive mb-4">
            <table class="table table-striped table-bordered bg-white">
                <thead>
                    <tr>
                        @if (isStaffOrAdmin)
                        {
                            <th>RequestID</th>
                            <th>UserID</th>
                            <th>Khách hàng</th>
                            <th>PetID</th>
                        }
                        <th>Thú cưng</th>
                        <th>Ngày gửi</th>
                        <th>Trạng thái</th>
                        <th>Người duyệt</th>
                        @if (isStaffOrAdmin)
                        {
                            <th>Duyệt yêu cầu</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Requests.Count == 0)
                    {
                        <tr>
                            <td colspan="@(isStaffOrAdmin ? 9 : 4)" class="text-center text-muted">Chưa có yêu cầu nhận nuôi.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Requests)
                        {
                            <tr>
                                @if (isStaffOrAdmin)
                                {
                                    <td>@item.RequestId</td>
                                    <td>@item.UserId</td>
                                    <td>@item.UserName</td>
                                    <td>@item.PetId</td>
                                }
                                <td>@item.PetName</td>
                                <td>@item.RequestDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge @StatusDisplay.BadgeClass(item.Status)">@StatusDisplay.Label(item.Status)</span></td>
                                <td>@item.ReviewedBy</td>
                                @if (isStaffOrAdmin)
                                {
                                    <td class="text-nowrap">
                                        @if (string.Equals(item.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <form method="post" asp-action="UpdateAdoptionRequestStatus" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="requestId" value="@item.RequestId" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                                <button type="submit" class="btn btn-sm btn-success">Chấp nhận</button>
                                            </form>
                                            <form method="post" asp-action="UpdateAdoptionRequestStatus" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="requestId" value="@item.RequestId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Từ chối</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <h4 class="mb-3" id="adoption-contracts">Hợp đồng nhận nuôi</h4>
        <div class="table-responsive mb-4">
            <table class="table table-striped table-bordered bg-white">
                <thead>
                    <tr>
                        @if (isStaffOrAdmin)
                        {
                            <th>ContractID</th>
                            <th>RequestID</th>
                            <th>UserID</th>
                            <th>Khách hàng</th>
                            <th>PetID</th>
                        }
                        <th>Thú cưng</th>
                        <th>Phí nhận nuôi</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Contracts.Count == 0)
                    {
                        <tr>
                            <td colspan="@(isStaffOrAdmin ? 8 : 3)" class="text-center text-muted">Chưa có hợp đồng nhận nuôi.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Contracts)
                        {
                            <tr>
                                @if (isStaffOrAdmin)
                                {
                                    <td>@item.ContractId</td>
                                    <td>@item.RequestId</td>
                                    <td>@item.UserId</td>
                                    <td>@item.UserName</td>
                                    <td>@item.PetId</td>
                                }
                                <td>@item.PetName</td>
                                <td>@item.AdoptionFee.ToString("N0") đ</td>
                                <td><span class="badge @StatusDisplay.BadgeClass(item.Status)">@StatusDisplay.Label(item.Status)</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <h4 class="mb-3" id="adoption-payments">Thanh toán nhận nuôi</h4>
        <div class="table-responsive">
            <table class="table table-striped table-bordered bg-white">
                <thead>
                    <tr>
                        @if (isStaffOrAdmin)
                        {
                            <th>PaymentID</th>
                            <th>ContractID</th>
                        }
                        <th>Số tiền</th>
                        <th>Phương thức</th>
                        <th>Ngày thanh toán</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Payments.Count == 0)
                    {
                        <tr>
                            <td colspan="@(isStaffOrAdmin ? 6 : 4)" class="text-center text-muted">Chưa có thanh toán nhận nuôi.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Payments)
                        {
                            <tr>
                                @if (isStaffOrAdmin)
                                {
                                    <td>@item.PaymentId</td>
                                    <td>@item.ContractId</td>
                                }
                                <td>@item.Amount.ToString("N0") đ</td>
                                <td>@item.PaymentMethod</td>
                                <td>@item.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge @StatusDisplay.BadgeClass(item.PaymentStatus)">@StatusDisplay.Label(item.PaymentStatus)</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = document.querySelectorAll('.btn-open-adoption');
            if (!buttons.length) {
                return;
            }

            const petIdInput = document.getElementById('requestPetId');
            const petNameText = document.getElementById('requestPetName');
            const messageInput = document.getElementById('requestMessage');

            buttons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const petId = button.getAttribute('data-pet-id') || '';
                    const petName = button.getAttribute('data-pet-name') || '';

                    if (petIdInput) petIdInput.value = petId;
                    if (petNameText) petNameText.textContent = petName;
                    if (messageInput) messageInput.value = '';

                    if (window.jQuery) {
                        window.jQuery('#adoptionRequestModal').modal('show');
                    }
                });
            });
        });
    </script>
}
