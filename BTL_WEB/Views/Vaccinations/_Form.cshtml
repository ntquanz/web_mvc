@model BTL_WEB.ViewModels.Medical.VaccinationFormViewModel

<form asp-action="@(Model.VaccinationId.HasValue ? "Edit" : "Create")" method="post">
    @if (Model.VaccinationId.HasValue)
    {
        <input asp-for="VaccinationId" type="hidden" />
    }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="PetId" class="form-label">Pet</label>
            <select asp-for="PetId" class="form-select" asp-items="Model.PetOptions"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="StaffId" class="form-label">Staff</label>
            @if (User.IsInRole("Staff"))
            {
                <select asp-for="StaffId" class="form-select" asp-items="Model.StaffOptions" disabled="disabled"></select>
                <input type="hidden" asp-for="StaffId" />
            }
            else
            {
                <select asp-for="StaffId" class="form-select" asp-items="Model.StaffOptions"></select>
            }
        </div>
        <div class="col-md-6">
            <label asp-for="VaccineName" class="form-label"></label>
            <input asp-for="VaccineName" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="VaccinationDate" class="form-label"></label>
            <input asp-for="VaccinationDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="NextDueDate" class="form-label"></label>
            <input asp-for="NextDueDate" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>
