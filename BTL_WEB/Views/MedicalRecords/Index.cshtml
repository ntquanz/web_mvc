@model IEnumerable<BTL_WEB.Models.MedicalRecord>
@{
    ViewData["Title"] = "Medical Records";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Medical Records</h1>
    <a asp-action="Create" asp-route-petId="@ViewBag.PetId" class="btn btn-primary">Add Record</a>
</div>
<table class="table table-bordered">
    <thead><tr><th>Date</th><th>Pet</th><th>Diagnosis</th><th>Staff</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.VisitDate.ToString("g")</td>
            <td>@item.Pet.Name</td>
            <td>@item.Diagnosis</td>
            <td>@item.Staff.User.FullName</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.RecordId" class="btn btn-sm btn-outline-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.RecordId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.RecordId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
