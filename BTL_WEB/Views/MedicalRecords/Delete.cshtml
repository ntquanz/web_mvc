@model BTL_WEB.Models.MedicalRecord
@{
    ViewData["Title"] = "Delete Medical Record";
}
<h1 class="h3 mb-3">Delete Medical Record</h1>
<div class="alert alert-warning">Xoa medical record cua pet <strong>@Model.Pet.Name</strong>?</div>
<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="RecordId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
